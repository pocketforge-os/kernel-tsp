	aw_gpiokey {
		compatible = "allwinner,aw_gpiokey";
		aw_gpiokey_int_port = <0x45 0x01 0x00 0x06 0x00 0x01 0x00>;
		status = "disabled";
	};

	acm8625 {
		compatible = "allwinner,acm8625";
		status = "disabled";
		acm8625-supply = <0x4f>;
		acm8625_power = "axp2202-aldo2";
		acm8625_power_vol = <0xdac>;
	};

